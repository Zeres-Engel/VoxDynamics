# ============================================================
# VoxDynamics — Environment Variables
# ============================================================

# PostgreSQL
POSTGRES_USER=voxdynamics
POSTGRES_PASSWORD=voxdynamics_secret
POSTGRES_DB=voxdynamics
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Database URL (async)
DATABASE_URL=postgresql+asyncpg://voxdynamics:voxdynamics_secret@postgres:5432/voxdynamics

# App
APP_HOST=0.0.0.0
APP_PORT=8000
GRADIO_PORT=7860
